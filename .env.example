# ──────────────────────────────────────────────────────────────────
# OCR SERVICE — Config
# Copia este archivo a `.env` y ajusta los valores para tu entorno.
# ──────────────────────────────────────────────────────────────────

# App
APP_NAME=OCR Service
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000
OCR_PORT=8000

# Security
# IMPORTANTE: generá una API key segura para producción
API_KEY=change-me-in-production

# Orígenes permitidos (CORS) — coma separados
ALLOWED_ORIGINS=["http://localhost","http://localhost:8080"]

RATE_LIMIT_PER_MINUTE=30

# File limits
MAX_UPLOAD_MB=20

# Tesseract
TESSERACT_LANG=spa+eng
TESSERACT_PSM=6
TESSERACT_OEM=3

# PDF
PDF_DPI=250
PDF_MAX_PAGES=10

# Preprocessing
PREPROCESS_ENABLED=true
